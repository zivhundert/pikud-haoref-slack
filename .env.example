# -------------------------------------------------------
# Required
# -------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
PIKUD_API_KEY=your-api-key-here

# -------------------------------------------------------
# Optional – SSE endpoint overrides
# -------------------------------------------------------
PIKUD_SSE_URL=http://localhost:8000/api/webhook/alerts
PIKUD_SSE_FALLBACK_URL=http://localhost:8000/api/alerts-stream

# -------------------------------------------------------
# Optional – Filtering
# -------------------------------------------------------
# Comma-separated city names (Hebrew). If empty, all cities pass.
CITY_FILTERS=
# Comma-separated region names. If empty, all regions pass.
REGION_FILTERS=
# Set to true to forward drill/test alerts as well.
INCLUDE_DRILLS=false

# -------------------------------------------------------
# Optional – Deduplication
# -------------------------------------------------------
DEDUPE_TTL_SECONDS=900

# -------------------------------------------------------
# Optional – Storage
# -------------------------------------------------------
DB_PATH=data/alerts.db
STATUS_FILE_PATH=data/status.json

# -------------------------------------------------------
# Optional – Runtime
# -------------------------------------------------------
LOG_LEVEL=INFO
TIMEZONE=Asia/Jerusalem

# -------------------------------------------------------
# Optional – Web dashboard
# -------------------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=8080
